@using BTCPayServer.Abstractions.Contracts
@using BTCPayServer.Abstractions.Extensions
@using NBitcoin
@inject IScopeProvider ScopeProvider
@model BTCPayServer.Plugins.ArkPayServer.Models.IntentBuilderViewModel

@{
    Layout = "_Layout";
    var pageTitle = "Arkade - Join Batch";
    ViewData.SetActivePage(category: "Ark", activePage: "IntentBuilder", title: pageTitle);
    var storeId = ScopeProvider.GetCurrentStoreId()!;
}

@section PageHeadContent
{
    <link rel="stylesheet" href="~/Resources/css/ark-plugin.css" asp-append-version="true" />
}

<partial name="_StatusMessage" />

<div class="sticky-header">
    <h2>
        <span>@pageTitle</span>
        <a href="#descriptor" data-bs-toggle="collapse">
            <vc:icon symbol="info" />
        </a>
    </h2>
</div>

<div id="descriptor" class="collapse">
    <div class="d-flex px-4 py-4 mb-4 bg-tile rounded">
        <div class="flex-fill">
            <p text-translate="true" class="mb-2">Join the next Arkade batch to consolidate or transfer your VTXOs.</p>
            <p text-translate="true" class="mb-3">
                Leave destination empty to consolidate to self, or specify an <strong>Arkade address</strong> for offchain transfer,
                <strong>Bitcoin address</strong> for onchain output, or <strong>Lightning invoice</strong> for instant payment.
            </p>
        </div>
        <button type="button" class="btn-close ms-auto" data-bs-toggle="collapse" data-bs-target="#descriptor" aria-expanded="false" aria-label="Close">
            <vc:icon symbol="close" />
        </button>
    </div>
</div>

@if (Model.Errors.Any())
{
    <div class="alert alert-danger">
        <ul class="mb-0">
            @foreach (var error in Model.Errors)
            {
                <li>@error</li>
            }
        </ul>
    </div>
}

<div class="row">
    <div class="col-12">
        @* Selected VTXOs Section *@
        <div class="card mb-4">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h5 class="mb-0">Selected Coins</h5>
                <span class="badge text-bg-primary">@Model.SelectedVtxos.Count VTXOs</span>
            </div>
            <div class="card-body p-0">
                @if (Model.SelectedVtxos.Any())
                {
                    <div class="table-responsive">
                        <table class="table table-sm mb-0">
                            <thead>
                                <tr>
                                    <th text-translate="true">Outpoint</th>
                                    <th text-translate="true">Amount</th>
                                    <th text-translate="true">Expiry</th>
                                    <th text-translate="true">Status</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var vtxo in Model.SelectedVtxos)
                                {
                                    <tr>
                                        <td>
                                            <vc:truncate-center text="@vtxo.Outpoint" classes="truncate-center-id"/>
                                        </td>
                                        <td>@vtxo.AmountBtc BTC</td>
                                        <td>
                                            @if (vtxo.ExpiresAt.HasValue)
                                            {
                                                <span class="vtxo-expiry" data-expires="@vtxo.ExpiresAt.Value.ToUnixTimeSeconds()">
                                                    @vtxo.ExpiresAt.Value.ToTimeAgo()
                                                </span>
                                            }
                                            else
                                            {
                                                <span class="text-muted">-</span>
                                            }
                                        </td>
                                        <td>
                                            @if (vtxo.IsRecoverable)
                                            {
                                                <span class="badge text-bg-warning">Recoverable</span>
                                            }
                                            else if (vtxo.CanSpendOffchain)
                                            {
                                                <span class="badge text-bg-success">Spendable</span>
                                            }
                                            else
                                            {
                                                <span class="badge text-bg-secondary">Not Spendable</span>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                            <tfoot>
                                <tr class="table-light">
                                    <th text-translate="true">Total</th>
                                    <th>@Money.Satoshis(Model.TotalSelectedAmount).ToDecimal(MoneyUnit.BTC) BTC</th>
                                    <th colspan="2"></th>
                                </tr>
                            </tfoot>
                        </table>
                    </div>
                }
                else
                {
                    <div class="p-4 text-center text-muted">
                        <p text-translate="true">No VTXOs selected. Go back and select VTXOs to spend.</p>
                        <a asp-action="Vtxos" asp-route-storeId="@storeId" class="btn btn-secondary">
                            <span text-translate="true">Select VTXOs</span>
                        </a>
                    </div>
                }
            </div>
        </div>

        @* Outputs Section *@
        @if (Model.SelectedVtxos.Any())
        {
            <form asp-action="BuildIntent" asp-route-storeId="@storeId" method="post" id="intent-form">
                <input type="hidden" name="VtxoOutpointsRaw" value="@Model.VtxoOutpointsRaw" />
                <input type="hidden" name="IsIntent" value="@Model.IsIntent.ToString().ToLower()" />

                <div class="card mb-4">
                    <div class="card-header d-flex justify-content-between align-items-center">
                        <h5 class="mb-0" text-translate="true">Outputs</h5>
                        <button type="button" class="btn btn-sm btn-outline-primary" id="add-output-btn">
                            <vc:icon symbol="actions-add" />
                            <span text-translate="true">Add Output</span>
                        </button>
                    </div>
                    <div class="card-body">
                        <div id="outputs-container">
                            @for (var i = 0; i < Model.Outputs.Count; i++)
                            {
                                var output = Model.Outputs[i];
                                <div class="output-row mb-3 p-3 border rounded @(i > 0 ? "" : "")" data-index="@i">
                                    <div class="d-flex justify-content-between align-items-start mb-2">
                                        <h6 class="mb-0">Output #@(i + 1)</h6>
                                        @if (i > 0)
                                        {
                                            <button type="button" class="btn btn-sm btn-outline-danger remove-output-btn">
                                                <vc:icon symbol="cross" />
                                            </button>
                                        }
                                    </div>

                                    <div class="row g-3">
                                        <div class="col-12">
                                            <label class="form-label" text-translate="true">Destination</label>
                                            <input type="text"
                                                   name="Outputs[@i].Destination"
                                                   value="@output.Destination"
                                                   class="form-control destination-input"
                                                   placeholder="Arkade address, BIP21 URI, or Lightning invoice (leave empty to consolidate to self)..." />
                                            <div class="form-text">
                                                <span text-translate="true">Arkade address = offchain VTXO, Bitcoin address = onchain output, or BOLT11 invoice (single output only). Leave empty to consolidate selected VTXOs to self.</span>
                                            </div>
                                            @if (!string.IsNullOrEmpty(output.Error))
                                            {
                                                <div class="text-danger mt-1">@output.Error</div>
                                            }
                                        </div>

                                        <div class="col-md-6">
                                            <label class="form-label" text-translate="true">Amount (BTC)</label>
                                            <input type="number"
                                                   name="Outputs[@i].AmountBtc"
                                                   value="@output.AmountBtc"
                                                   class="form-control amount-input"
                                                   step="0.00000001"
                                                   min="0"
                                                   placeholder="0.00000000" />
                                            <div class="form-text" text-translate="true">Required unless destination includes amount (BOLT11 or BIP21 with amount).</div>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>

                        <div class="alert alert-info mt-3" id="lightning-notice" style="display: none;">
                            <vc:icon symbol="info" />
                            <span text-translate="true">Lightning payments only support a single output. Additional outputs have been disabled.</span>
                        </div>
                    </div>
                </div>

                @* Fee Estimate Section *@
                <div class="card mb-4" id="fee-card">
                    <div class="card-header">
                        <h5 class="mb-0" text-translate="true">Estimated Fees</h5>
                    </div>
                    <div class="card-body">
                        <div id="fee-loading" style="display: none;">
                            <span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>
                            <span text-translate="true">Calculating fees...</span>
                        </div>
                        <div id="fee-error" class="text-danger" style="display: none;"></div>
                        <div id="fee-display" style="display: none;">
                            <div class="row">
                                <div class="col-md-6">
                                    <div class="mb-2">
                                        <small class="text-muted" text-translate="true">Service Fee</small>
                                        <div class="fw-bold" id="fee-amount">-</div>
                                        <small class="text-muted" id="fee-description"></small>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="mb-2">
                                        <small class="text-muted" text-translate="true">You Will Receive</small>
                                        <div class="fw-bold text-success" id="net-amount">-</div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div id="fee-hint" class="text-muted" style="display: none;">
                            <small text-translate="true">Calculating fee estimate...</small>
                        </div>
                    </div>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary" id="submit-btn">
                        <vc:icon symbol="actions-send" />
                        <span text-translate="true">Join Batch</span>
                    </button>
                    <a asp-action="StoreOverview" asp-route-storeId="@storeId" class="btn btn-secondary">
                        <span text-translate="true">Cancel</span>
                    </a>
                </div>
            </form>
        }
    </div>
</div>

@section PageFootContent {
    <script>
        (function() {
            const container = document.getElementById('outputs-container');
            const addBtn = document.getElementById('add-output-btn');
            const lightningNotice = document.getElementById('lightning-notice');
            const feeLoading = document.getElementById('fee-loading');
            const feeError = document.getElementById('fee-error');
            const feeDisplay = document.getElementById('fee-display');
            const feeHint = document.getElementById('fee-hint');
            const feeAmount = document.getElementById('fee-amount');
            const feeDescription = document.getElementById('fee-description');
            const netAmount = document.getElementById('net-amount');

            const storeId = '@storeId';
            const totalInputSats = @Model.TotalSelectedAmount;
            const vtxoOutpoints = '@Model.VtxoOutpointsRaw'.split(',').filter(x => x);

            let outputIndex = @Model.Outputs.Count;
            let feeDebounceTimer = null;

            // Add output row
            addBtn?.addEventListener('click', function() {
                const template = `
                    <div class="output-row mb-3 p-3 border rounded" data-index="${outputIndex}">
                        <div class="d-flex justify-content-between align-items-start mb-2">
                            <h6 class="mb-0">Output #${outputIndex + 1}</h6>
                            <button type="button" class="btn btn-sm btn-outline-danger remove-output-btn">
                                <svg class="icon icon-cross"><use href="/img/icon-sprite.svg#cross"></use></svg>
                            </button>
                        </div>
                        <div class="row g-3">
                            <div class="col-12">
                                <label class="form-label">Destination</label>
                                <input type="text"
                                       name="Outputs[${outputIndex}].Destination"
                                       class="form-control destination-input"
                                       placeholder="Arkade address, BIP21 URI, or Lightning invoice..." />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Amount (BTC)</label>
                                <input type="number"
                                       name="Outputs[${outputIndex}].AmountBtc"
                                       class="form-control amount-input"
                                       step="0.00000001"
                                       min="0"
                                       placeholder="0.00000000" />
                                <div class="form-text">Required unless destination includes amount.</div>
                            </div>
                        </div>
                    </div>
                `;
                container.insertAdjacentHTML('beforeend', template);
                outputIndex++;
                updateRemoveButtons();
                scheduleFeeEstimate();
            });

            // Remove output row
            container?.addEventListener('click', function(e) {
                const removeBtn = e.target.closest('.remove-output-btn');
                if (removeBtn) {
                    const row = removeBtn.closest('.output-row');
                    row.remove();
                    reindexOutputs();
                    updateRemoveButtons();
                    scheduleFeeEstimate();
                }
            });

            // Detect input changes for Lightning check and fee estimation
            container?.addEventListener('input', function(e) {
                if (e.target.classList.contains('destination-input') || e.target.classList.contains('amount-input')) {
                    checkForLightning();
                    scheduleFeeEstimate();
                }
            });

            function checkForLightning() {
                const inputs = container.querySelectorAll('.destination-input');
                let hasLightning = false;

                inputs.forEach(input => {
                    const value = input.value.toLowerCase().trim();
                    if (value.startsWith('ln') || value.startsWith('lightning:')) {
                        hasLightning = true;
                    }
                });

                if (hasLightning) {
                    lightningNotice.style.display = 'block';
                    addBtn.disabled = true;
                } else {
                    lightningNotice.style.display = 'none';
                    addBtn.disabled = false;
                }
            }

            function reindexOutputs() {
                const rows = container.querySelectorAll('.output-row');
                rows.forEach((row, index) => {
                    row.dataset.index = index;
                    row.querySelector('h6').textContent = `Output #${index + 1}`;

                    const destInput = row.querySelector('input[name*="Destination"]');
                    const amountInput = row.querySelector('input[name*="AmountBtc"]');

                    if (destInput) destInput.name = `Outputs[${index}].Destination`;
                    if (amountInput) amountInput.name = `Outputs[${index}].AmountBtc`;
                });
                outputIndex = rows.length;
            }

            function updateRemoveButtons() {
                const rows = container.querySelectorAll('.output-row');
                rows.forEach((row, index) => {
                    const removeBtn = row.querySelector('.remove-output-btn');
                    if (removeBtn) {
                        removeBtn.style.display = rows.length > 1 ? '' : 'none';
                    }
                });
            }

            function scheduleFeeEstimate() {
                if (feeDebounceTimer) clearTimeout(feeDebounceTimer);
                feeDebounceTimer = setTimeout(estimateFees, 500);
            }

            async function estimateFees() {
                const outputs = [];
                const rows = container.querySelectorAll('.output-row');

                rows.forEach(row => {
                    const destInput = row.querySelector('.destination-input');
                    const amountInput = row.querySelector('.amount-input');

                    const destination = destInput?.value?.trim() || '';
                    const amountBtc = parseFloat(amountInput?.value) || 0;
                    const amountSats = amountBtc > 0 ? Math.round(amountBtc * 100000000) : null;

                    // Include output even if destination is empty (consolidation case)
                    outputs.push({ destination: destination || null, amountSats });
                });

                // Show loading
                feeHint.style.display = 'none';
                feeDisplay.style.display = 'none';
                feeError.style.display = 'none';
                feeLoading.style.display = 'block';

                try {
                    const response = await fetch(`/plugins/ark/stores/${storeId}/estimate-fees`, {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json',
                            'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]')?.value || ''
                        },
                        body: JSON.stringify({
                            vtxoOutpoints: vtxoOutpoints,
                            totalInputSats: totalInputSats,
                            outputs: outputs
                        })
                    });

                    const result = await response.json();
                    feeLoading.style.display = 'none';

                    if (result.error) {
                        feeError.textContent = result.error;
                        feeError.style.display = 'block';
                        return;
                    }

                    // Calculate amounts
                    const feeSats = result.estimatedFeeSats || 0;
                    const feeBtc = (feeSats / 100000000).toFixed(8);

                    const netSats = totalInputSats - feeSats;
                    const netBtc = (netSats / 100000000).toFixed(8);

                    // Display
                    feeAmount.textContent = `${feeBtc} BTC (${feeSats.toLocaleString()} sats)`;
                    feeDescription.textContent = result.feeDescription || 'Arkade service fee';
                    netAmount.textContent = `${netBtc} BTC`;

                    if (result.isLightning && result.feePercentage) {
                        feeDescription.textContent = `${result.feePercentage.toFixed(2)}% + ${result.minerFeeSats} sats miner fee`;
                    }

                    feeDisplay.style.display = 'block';

                } catch (err) {
                    feeLoading.style.display = 'none';
                    feeError.textContent = 'Failed to estimate fees: ' + err.message;
                    feeError.style.display = 'block';
                }
            }

            // Initial checks
            checkForLightning();
            updateRemoveButtons();
            scheduleFeeEstimate();
        })();
    </script>
}
