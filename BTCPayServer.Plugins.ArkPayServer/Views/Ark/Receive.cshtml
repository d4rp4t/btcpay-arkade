@using BTCPayServer.Abstractions.Contracts
@using BTCPayServer.Abstractions.Extensions
@using BTCPayServer.Components.QRCode
@using BTCPayServer.Plugins.ArkPayServer.PaymentHandler
@inject IScopeProvider ScopeProvider
@model BTCPayServer.Plugins.ArkPayServer.Models.ArkReceiveViewModel
@{
    var storeId = ScopeProvider.GetCurrentStoreId();
    var returnUrl = Url.Action("StoreOverview", "Ark", new { storeId });
    Layout = "_LayoutWizard";
    ViewData.SetTitle("Receive Arkade");
    var hasAddress = !string.IsNullOrEmpty(Model.Address);
    var hasBoarding = !string.IsNullOrEmpty(Model.BoardingAddress);
    var hasAny = hasAddress || hasBoarding;
}

@section PageHeadContent
{
    <link href="~/main/qrcode.css" rel="stylesheet" asp-append-version="true" />
}

@section Navbar {
    <a href="@returnUrl" id="CancelWizard" class="cancel">
        <vc:icon symbol="cross" />
    </a>
}

<header class="text-center">
    <h1 class="mb-4">@ViewData["Title"]</h1>
</header>

<partial name="_ArkadeOperatorStatusBanner" />

<form method="post" asp-action="Receive" asp-route-storeId="@storeId">
    @if (!hasAny)
    {
        <div class="payment-box mb-3">
            <button id="generateButton" class="btn btn-primary w-100" type="submit" name="command" value="generate-address">
                Generate receive address
            </button>
        </div>
        <div class="payment-box mb-3">
            <button class="btn btn-outline-primary w-100" type="submit" name="command" value="generate-boarding-address">
                Generate boarding address
            </button>
            <p class="text-muted small text-center mt-2 mb-0">Onchain Bitcoin deposit into Arkade</p>
        </div>
    }
    else
    {
        // Single source of truth for BIP-21 — same shape the checkout uses
        // (bitcoin:<boarding>?ark=<arkAddress>): wallets that only speak
        // standard BIP-21 see the boarding address as the payable target;
        // Arkade-aware wallets pick up the ark= param too.
        string? paymentLink = null;
        if (hasAddress)
        {
            paymentLink = ArkadeBip21Builder.Create()
                .WithArkAddress(Model.Address!)
                .WithOnchainAddress(hasBoarding ? Model.BoardingAddress : null)
                .Build();
        }
        <noscript>
            @if (hasAddress)
            {
                <div class="form-group">
                    <input type="text" class="form-control" readonly="readonly" value="@Model.Address" />
                </div>
            }
            @if (hasBoarding)
            {
                <div class="form-group">
                    <input type="text" class="form-control" readonly="readonly" value="@Model.BoardingAddress" />
                </div>
            }
        </noscript>
        <div class="nav flex-wrap align-items-center justify-content-center gap-2 mb-4">
            @if (hasAddress)
            {
                <a class="btcpay-pill" data-bs-toggle="tab" href="#address-tab">Address</a>
                <a class="btcpay-pill active" data-bs-toggle="tab" href="#link-tab">Link</a>
            }
            @if (hasBoarding)
            {
                <a class="btcpay-pill @(!hasAddress ? "active" : "")" data-bs-toggle="tab" href="#boarding-tab">Boarding</a>
            }
        </div>
        <div class="only-for-js col-sm-10 col-xxl-8 mx-auto" id="app">
            <div class="tab-content text-center">
                @if (hasAddress)
                {
                    <div class="tab-pane payment-box" id="address-tab" role="tabpanel">
                        <div class="qr-container" data-clipboard="@Model.Address">
                            <vc:qr-code data="@Model.Address" />
                        </div>
                        <div class="input-group mt-3">
                            <div class="form-floating">
                                <vc:truncate-center text="@Model.Address" padding="15" elastic="true" classes="form-control-plaintext" id="Address" />
                                <label for="Address">Arkade Address</label>
                            </div>
                        </div>
                    </div>
                    <div class="tab-pane payment-box show active" id="link-tab" role="tabpanel">
                        <div class="qr-container" data-clipboard="@paymentLink">
                            <vc:qr-code data="@paymentLink" />
                        </div>
                        <div class="input-group mt-3">
                            <div class="form-floating">
                                <vc:truncate-center text="@paymentLink" padding="15" elastic="true" classes="form-control-plaintext" id="PaymentLink" />
                                <label for="PaymentLink">Payment Link</label>
                            </div>
                        </div>
                    </div>
                }
                @if (hasBoarding)
                {
                    <div class="tab-pane payment-box @(!hasAddress ? "show active" : "")" id="boarding-tab" role="tabpanel">
                        <div class="qr-container" data-clipboard="@Model.BoardingAddress">
                            <vc:qr-code data="@Model.BoardingAddress" />
                        </div>
                        <div class="input-group mt-3">
                            <div class="form-floating">
                                <vc:truncate-center text="@Model.BoardingAddress" padding="15" elastic="true" classes="form-control-plaintext" id="BoardingAddress" />
                                <label for="BoardingAddress">Boarding Address (Onchain)</label>
                            </div>
                        </div>
                        <p class="text-muted small mt-2 mb-0">Send onchain BTC to board into Arkade. Requires 1 confirmation + batch round.</p>
                    </div>
                }
            </div>
        </div>
        <div class="mt-2 d-flex flex-column align-items-center">
            @* "New X" is a refresh action once the address already exists, so a
               quiet text button is the right visual weight; "Generate X" stays
               a prominent CTA when that address is still missing. Stacked
               vertically with minimal padding so each label fits on one line. *@
            <button type="submit" name="command" value="generate-address"
                    class="btn @(hasAddress ? "btn-link py-1" : "btn-primary")">
                @(hasAddress ? "New Arkade address" : "Generate Arkade address")
            </button>
            <button type="submit" name="command" value="generate-boarding-address"
                    class="btn @(hasBoarding ? "btn-link py-1" : "btn-outline-primary")">
                @(hasBoarding ? "New boarding address" : "Generate boarding address")
            </button>
        </div>
        <p class="text-muted small text-center mt-3 mb-0">Addresses auto-deactivate once funds arrive</p>
    }
</form>
