@using BTCPayServer.Abstractions.Contracts
@using BTCPayServer.Abstractions.Extensions
@using BTCPayServer.Plugins.ArkPayServer.Helpers
@using NBitcoin
@using NArk.Abstractions.VTXOs
@model BTCPayServer.Plugins.ArkPayServer.Models.SendWizardViewModel
@inject IScopeProvider ScopeProvider
@inject ArkNetworkConfig ArkNetworkConfig
@inject BTCPayServer.Security.ContentSecurityPolicies Csp

@{
    ViewData.SetActivePage(category: "Ark", activePage: "Send", title: "Arkade - Send");
    Csp.UnsafeEval();
    var storeId = ScopeProvider.GetCurrentStoreId();
}

@section PageHeadContent
{
    <link rel="stylesheet" href="~/Resources/css/ark-plugin.css" asp-append-version="true" />
    <link href="~/vendor/vue-qrcode-reader/vue-qrcode-reader.css" rel="stylesheet" asp-append-version="true"/>
    <style>
        /* Wizard section tiles - BTCPay modern style */
        .wizard-section {
            background: var(--btcpay-bg-tile);
            border-radius: var(--btcpay-border-radius-l, 0.5rem);
            margin-bottom: 1rem;
            overflow: hidden;
        }
        .wizard-section-header {
            padding: 1rem 1.25rem;
            cursor: pointer;
            display: flex;
            justify-content: space-between;
            align-items: center;
            border-bottom: 1px solid transparent;
            transition: border-color 0.2s;
        }
        .wizard-section:not(.collapsed) .wizard-section-header {
            border-bottom-color: var(--btcpay-body-border-light);
        }
        .wizard-section-header:hover {
            background: var(--btcpay-body-bg-hover, rgba(0,0,0,0.02));
        }
        .wizard-section-body {
            padding: 1.25rem;
        }
        .wizard-section.collapsed .wizard-section-body {
            display: none;
        }
        .wizard-section.collapsed .wizard-section-header .section-icon {
            transform: rotate(-90deg);
        }
        .section-icon {
            transition: transform 0.2s;
        }
        .section-summary {
            font-size: 0.875rem;
            color: var(--btcpay-body-text-muted);
        }
        .output-row {
            background: var(--btcpay-body-bg);
            border-radius: var(--btcpay-border-radius, 0.25rem);
            padding: 1rem;
            margin-bottom: 0.75rem;
        }
        .coin-summary {
            display: flex;
            gap: 1rem;
            align-items: center;
        }
        .spend-type-badge {
            font-size: 0.75rem;
            padding: 0.25rem 0.5rem;
        }
        .destination-type-badge:empty {
            display: none;
        }
        .bip21-display input {
            background: var(--btcpay-body-bg);
            font-size: 0.75rem;
        }
    </style>
}

<div class="sticky-header">
    <h2>
        <span>@ViewData["Title"]</span>
        <a href="#descriptor" data-bs-toggle="collapse">
            <vc:icon symbol="info" />
        </a>
    </h2>
</div>

<div id="descriptor" class="collapse">
    <div class="d-flex px-4 py-4 mb-4 bg-tile rounded">
        <div class="flex-fill">
            <p text-translate="true" class="mb-2">Send funds using the Arkade protocol.</p>
            <p text-translate="true" class="mb-3">Supports Arkade addresses (instant offchain), Bitcoin addresses (batch settlement), and Lightning invoices (via swap).</p>
        </div>
        <button type="button" class="btn-close ms-auto" data-bs-toggle="collapse" data-bs-target="#descriptor" aria-expanded="false" aria-label="Close">
            <vc:icon symbol="close" />
        </button>
    </div>
</div>

<partial name="_StatusMessage" />
<partial name="_ArkadeOperatorStatusBanner" />

@if (Model.Errors.Any())
{
    <div class="alert alert-danger alert-dismissible" id="server-errors-alert">
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        <ul class="mb-0">
            @foreach (var error in Model.Errors)
            {
                <li>@error</li>
            }
        </ul>
    </div>
}

@if (!Model.AvailableVtxos.Any())
{
    @if (Model.Balances != null)
    {
        <partial name="_ArkBalances" model="Model.Balances" />
    }
}
else
{
    <form method="post" asp-action="Send" asp-route-storeId="@Model.StoreId" id="send-wizard-form">
        <input type="hidden" name="CoinSelectionMode" id="coin-selection-mode-field" value="@Model.CoinSelectionMode" />
        <!-- Destination Section -->
        <div class="wizard-section" id="destination-section">
            <div class="wizard-section-header" onclick="toggleSection('destination-section')">
                <div>
                    <vc:icon symbol="caret-down" css-class="section-icon" />
                    <strong text-translate="true">Destination</strong>
                </div>
                <span class="section-summary" id="destination-summary"></span>
            </div>
            <div class="wizard-section-body">
                <div id="outputs-container">
                    @for (int i = 0; i < Math.Max(1, Model.Outputs.Count); i++)
                    {
                        var output = i < Model.Outputs.Count ? Model.Outputs[i] : new BTCPayServer.Plugins.ArkPayServer.Models.SendOutputViewModel();
                        <div class="output-row" data-index="@i">
                            @if (output.IsBip21Parsed && !string.IsNullOrEmpty(output.RawBip21))
                            {
                                <div class="mb-2 bip21-display">
                                    <label class="form-label text-muted small" text-translate="true">BIP21 URI</label>
                                    <input type="text" class="form-control form-control-sm font-monospace"
                                           value="@output.RawBip21" readonly />
                                    <input type="hidden" name="Outputs[@i].RawBip21" value="@output.RawBip21" />
                                </div>
                            }
                            <div class="row g-3">
                                <div class="col-12 col-md-7">
                                    <label class="form-label" text-translate="true">Address, Invoice, or BIP21</label>
                                    <div class="input-group">
                                        <input type="text"
                                               name="Outputs[@i].Destination"
                                               value="@output.Destination"
                                               class="form-control destination-input"
                                               placeholder="Leave empty to consolidate, or paste address..."
                                               data-index="@i"
                                               @(output.IsReadonly ? "readonly" : "") />
                                        <button type="button"
                                                class="btn btn-secondary px-3 only-for-js scan-qr-btn"
                                                data-index="@i"
                                                title="Scan QR code">
                                            <vc:icon symbol="scan-qr" />
                                        </button>
                                    </div>
                                    @if (!string.IsNullOrEmpty(output.Error))
                                    {
                                        <div class="text-danger small mt-1">@output.Error</div>
                                    }
                                </div>
                                <div class="col-12 col-md-3">
                                    <label class="form-label" text-translate="true">Amount (BTC)</label>
                                    <div class="input-group">
                                        <input type="number"
                                               name="Outputs[@i].AmountBtc"
                                               value="@output.AmountBtc"
                                               class="form-control amount-input"
                                               placeholder="Optional"
                                               step="0.00000001"
                                               min="0"
                                               data-index="@i"
                                               @(output.IsReadonly && output.AmountBtc.HasValue ? "readonly" : "") />
                                        <button type="button" class="btn btn-outline-secondary max-amount-btn only-for-js" data-index="@i" title="Fill remaining balance">Max</button>
                                    </div>
                                    <small class="remaining-balance-hint text-muted d-none mt-1"></small>
                                </div>
                                <div class="col-12 col-md-1 d-flex align-items-center" style="margin-top: 1.75rem;">
                                    <button type="button" class="btn btn-link text-danger remove-output-btn p-0" data-index="@i"
                                            style="@(i == 0 && Model.Outputs.Count == 1 && string.IsNullOrWhiteSpace(output.Destination) ? "display:none" : "")"
                                            title="Remove destination">
                                        <vc:icon symbol="cross" />
                                    </button>
                                </div>
                            </div>
                            <input type="hidden" name="Outputs[@i].PayoutId" value="@output.PayoutId" />
                            <input type="hidden" name="Outputs[@i].IsReadonly" value="@output.IsReadonly.ToString().ToLower()" />
                            <input type="hidden" name="Outputs[@i].IsBip21Parsed" value="@output.IsBip21Parsed.ToString().ToLower()" />
                            <div class="mt-2 d-flex align-items-center gap-2">
                                <span class="destination-type-badge badge @output.TypeBadgeClass" data-index="@i">
                                    @output.TypeBadge
                                </span>
                                @if (!string.IsNullOrEmpty(output.PayoutId))
                                {
                                    <span class="badge bg-info">
                                        Fulfilling payout
                                    </span>
                                }
                            </div>
                        </div>
                    }
                </div>
                <button type="button" id="add-output-btn" class="btn btn-link p-0 mt-2">
                    <vc:icon symbol="actions-add" />
                    <span text-translate="true">Add another output</span>
                </button>
            </div>
        </div>

        <!-- Coins Section - collapsed by default in auto mode (no preselected coins) -->
        <div class="wizard-section @(Model.CoinSelectionMode == "manual" ? "" : "collapsed")" id="coins-section">
            <div class="wizard-section-header" onclick="toggleSection('coins-section')">
                <div>
                    <vc:icon symbol="caret-down" css-class="section-icon" />
                    <strong text-translate="true">Coins</strong>
                </div>
                <div class="coin-summary d-flex align-items-center gap-2">
                    <span id="coins-summary">@Model.SelectedCount selected - @Model.TotalSelectedBtc.ToString("0.00000000") BTC</span>
                    <span class="badge text-bg-secondary" id="selection-mode-badge">@Model.CoinSelectionMode</span>
                    <button type="button" class="btn btn-link btn-sm p-0 text-muted" id="reset-to-auto-btn" style="display: none;" title="Switch to automatic coin selection">
                        <small>Switch to automatic</small>
                    </button>
                </div>
            </div>
            <div class="wizard-section-body">
                <!-- Quick select buttons and total balance -->
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <div class="btn-group btn-group-sm" role="group" aria-label="Quick select">
                        <button type="button" class="btn btn-outline-secondary" id="select-active-btn" title="Select all active (non-recoverable) coins">Select Active</button>
                        <button type="button" class="btn btn-outline-secondary" id="select-recoverable-btn" title="Select all recoverable coins">Select Recoverable</button>
                    </div>
                    <div class="text-muted small" id="total-balance-display">
                        Total: <strong>@Model.TotalAvailableBtc.ToString("0.00000000") BTC</strong>
                        <span class="ms-2">(@Model.AvailableVtxos.Count() coins)</span>
                    </div>
                </div>
                <div class="table-responsive">
                    <table id="coins-table" class="table table-sm">
                        <thead>
                            <tr>
                                <th style="width: 32px;">
                                    <input type="checkbox" class="form-check-input" id="select-all-coins" />
                                </th>
                                <th text-translate="true">Outpoint</th>
                                <th text-translate="true">Amount</th>
                                <th text-translate="true">Expiry</th>
                                <th text-translate="true">Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var vtxo in Model.AvailableVtxos)
                            {
                                var outpoint = $"{vtxo.TransactionId}:{vtxo.TransactionOutputIndex}";
                                var shortOutpoint = ArkadeLinkHelper.FormatOutpoint(vtxo.TransactionId, vtxo.TransactionOutputIndex);
                                var link = ArkadeLinkHelper.GetOutpointLink(ArkNetworkConfig, vtxo.TransactionId, vtxo.TransactionOutputIndex);
                                var isSelected = Model.SelectedVtxos.Any(s =>
                                    s.TransactionId == vtxo.TransactionId &&
                                    s.TransactionOutputIndex == vtxo.TransactionOutputIndex);

                                <tr>
                                    <td>
                                        <input type="checkbox"
                                               name="selectedVtxoOutpoints"
                                               value="@outpoint"
                                               class="form-check-input coin-checkbox"
                                               @(isSelected ? "checked" : "") />
                                    </td>
                                    <td>
                                        <vc:truncate-center link="@link" text="@shortOutpoint" classes="truncate-center-id"/>
                                    </td>
                                    <td>@Money.Satoshis((long)vtxo.Amount).ToDecimal(MoneyUnit.BTC) BTC</td>
                                    <td>
                                        @if (vtxo.ExpiresAt.HasValue)
                                        {
                                            <span class="vtxo-expiry" data-expires="@vtxo.ExpiresAt.Value.ToUnixTimeSeconds()">
                                                @vtxo.ExpiresAt.Value.ToTimeAgo()
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="text-muted">-</span>
                                        }
                                    </td>
                                    <td>
                                        @if (vtxo.Swept)
                                        {
                                            <span class="badge text-bg-warning" data-coin-type="recoverable" title="Requires batch transaction to spend">Batch Only</span>
                                        }
                                        else
                                        {
                                            <span data-coin-type="spendable"></span>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <!-- Spend Type Section -->
        <div class="wizard-section" id="spend-type-section">
            <div class="wizard-section-header" onclick="toggleSection('spend-type-section')">
                <div>
                    <vc:icon symbol="caret-down" css-class="section-icon" />
                    <strong text-translate="true">Transaction Type</strong>
                </div>
                <span class="section-summary" id="spend-type-summary"></span>
            </div>
            <div class="wizard-section-body">
                <div class="form-check mb-2">
                    <input class="form-check-input" type="radio" name="SpendType" id="spend-type-arkade" value="Arkade" checked>
                    <label class="form-check-label" for="spend-type-arkade">
                        <strong>Arkade</strong>
                        <span class="text-muted d-block small">Instant, no fees. Preconfirmed state.</span>
                    </label>
                </div>
                <div class="form-check">
                    <input class="form-check-input" type="radio" name="SpendType" id="spend-type-batch" value="Batch">
                    <label class="form-check-label" for="spend-type-batch">
                        <strong>Batch</strong>
                        <span class="text-muted d-block small">Achieves Bitcoin finality for your coins, allows paying onchain, renews your expiry. Not instant, must wait for batch and has variable fees based on your transaction.</span>
                    </label>
                </div>
            </div>
        </div>

        <!-- Review Section -->
        <div class="wizard-section collapsed" id="review-section">
            <div class="wizard-section-header" onclick="toggleSection('review-section')">
                <div>
                    <vc:icon symbol="caret-down" css-class="section-icon" />
                    <strong text-translate="true">Review</strong>
                </div>
                <span class="section-summary" id="review-summary"></span>
            </div>
            <div class="wizard-section-body">
                <div id="review-content">
                    <p class="text-muted" text-translate="true">Complete the destination to see transaction summary.</p>
                </div>
            </div>
        </div>

        <!-- Footer -->
        <div class="d-flex justify-content-end align-items-center mt-4 gap-2">
            <a asp-action="StoreOverview" asp-route-storeId="@Model.StoreId" class="btn btn-secondary" text-translate="true">Cancel</a>
            <button type="submit" class="btn btn-primary" id="send-btn" disabled>
                <span text-translate="true">Send</span>
            </button>
        </div>
    </form>
}

<partial name="CameraScanner"/>

@section PageFootContent
{
    <script src="~/vendor/vuejs/vue.min.js" asp-append-version="true"></script>
    <script src="~/vendor/ur-registry/urlib.min.js" asp-append-version="true"></script>
    <script src="~/vendor/vue-qrcode-reader/VueQrcodeReader.umd.min.js" asp-append-version="true"></script>
    <script>
    (function() {
        'use strict';

        // State
        const state = {
            coinSelectionMode: '@Model.CoinSelectionMode',
            detectedSpendType: null,
            estimatedFee: null,
            isLightning: false,
            hasBitcoinAddress: false,
            userSpendType: 'Arkade', // User's choice - influences auto coin selection
            // Set when the user clicks "Max" so that the next estimate-fees
            // response can revise the amount to (gross - fee). Without this,
            // batch / collab-exit sends were filled to the full balance and
            // the user had to subtract the fee by hand to submit.
            pendingMaxAdjustment: null
        };

        // DOM elements
        const form = document.getElementById('send-wizard-form');
        const outputsContainer = document.getElementById('outputs-container');
        const addOutputBtn = document.getElementById('add-output-btn');
        const coinsTable = document.getElementById('coins-table');
        const selectAllCoins = document.getElementById('select-all-coins');
        const sendBtn = document.getElementById('send-btn');
        const coinsSummary = document.getElementById('coins-summary');
        const selectionModeBadge = document.getElementById('selection-mode-badge');
        const reviewSummary = document.getElementById('review-summary');
        const reviewContent = document.getElementById('review-content');
        const spendTypeSection = document.getElementById('spend-type-section');
        const spendTypeSummary = document.getElementById('spend-type-summary');
        const spendTypeArkade = document.getElementById('spend-type-arkade');
        const spendTypeBatch = document.getElementById('spend-type-batch');
        const resetToAutoBtn = document.getElementById('reset-to-auto-btn');
        const selectActiveBtn = document.getElementById('select-active-btn');
        const selectRecoverableBtn = document.getElementById('select-recoverable-btn');
        const coinSelectionModeField = document.getElementById('coin-selection-mode-field');

        // Update coin selection mode (state + hidden field)
        function setCoinSelectionMode(mode) {
            state.coinSelectionMode = mode;
            if (coinSelectionModeField) coinSelectionModeField.value = mode;
        }

        // Debounce helper
        function debounce(fn, delay) {
            let timeout;
            return function(...args) {
                clearTimeout(timeout);
                timeout = setTimeout(() => fn.apply(this, args), delay);
            };
        }

        // Toggle section collapse
        window.toggleSection = function(sectionId) {
            const section = document.getElementById(sectionId);
            section.classList.toggle('collapsed');
        };

        // Select coins by type
        function selectCoinsByType(type) {
            setCoinSelectionMode('manual');
            const rows = coinsTable.querySelectorAll('tbody tr');
            rows.forEach(row => {
                const badge = row.querySelector('[data-coin-type]');
                const cb = row.querySelector('.coin-checkbox');
                if (!badge || !cb) return;

                const coinType = badge.dataset.coinType; // 'recoverable' or 'spendable'
                cb.checked = (coinType === type);
            });

            updateCoinsSummary();
            handleCoinSelectionChange();
        }

        // Select all visible coins
        function selectAllCoinsVisible(select) {
            const rows = coinsTable.querySelectorAll('tbody tr');
            rows.forEach(row => {
                const cb = row.querySelector('.coin-checkbox');
                if (cb) cb.checked = select;
            });
        }

        // Get selected coins
        function getSelectedCoins() {
            const checkboxes = coinsTable.querySelectorAll('.coin-checkbox:checked');
            return Array.from(checkboxes).map(cb => cb.value);
        }

        // Update coins summary
        function updateCoinsSummary() {
            const checkboxes = coinsTable.querySelectorAll('.coin-checkbox:checked');
            const count = checkboxes.length;
            let totalSats = 0;

            checkboxes.forEach(cb => {
                const row = cb.closest('tr');
                const amountText = row.cells[2].textContent;
                const btc = parseFloat(amountText);
                totalSats += Math.round(btc * 100000000);
            });

            const totalBtc = (totalSats / 100000000).toFixed(8);

            // In auto mode with no selection, show total available balance
            if (state.coinSelectionMode === 'auto' && count === 0) {
                const totalAvailable = @((Model.TotalAvailableSats / 100_000_000m).ToString("0.00000000", System.Globalization.CultureInfo.InvariantCulture));
                const totalCoins = @Model.AvailableVtxos.Count();
                coinsSummary.textContent = `${totalCoins} coins · ${totalAvailable} BTC available`;
            } else {
                coinsSummary.textContent = `${count} selected · ${totalBtc} BTC`;
            }

            selectionModeBadge.textContent = state.coinSelectionMode;

            // Show/hide reset button based on mode
            if (resetToAutoBtn) {
                resetToAutoBtn.style.display = state.coinSelectionMode === 'manual' ? '' : 'none';
            }
        }

        // Update remaining balance hints next to amount fields
        function updateRemainingBalance() {
            // Calculate total selected sats
            let totalSelectedSats = 0;
            coinsTable.querySelectorAll('.coin-checkbox:checked').forEach(cb => {
                const row = cb.closest('tr');
                const amountText = row.cells[2].textContent;
                totalSelectedSats += Math.round(parseFloat(amountText) * 100000000);
            });

            // Calculate total allocated across all outputs
            const outputRows = outputsContainer.querySelectorAll('.output-row');
            let totalAllocated = 0;
            outputRows.forEach(row => {
                const amountInput = row.querySelector('.amount-input');
                if (amountInput?.value) {
                    totalAllocated += Math.round(parseFloat(amountInput.value) * 100000000);
                }
            });

            // Update each row's remaining hint
            outputRows.forEach(row => {
                const hint = row.querySelector('.remaining-balance-hint');
                const amountInput = row.querySelector('.amount-input');
                const destInput = row.querySelector('.destination-input');
                if (!hint) return;

                // Only show when there's a destination and coins are selected
                if (!destInput?.value?.trim() || totalSelectedSats === 0) {
                    hint.classList.add('d-none');
                    return;
                }

                const remaining = totalSelectedSats - totalAllocated;
                const remainingBtc = (remaining / 100000000).toFixed(8);
                hint.classList.remove('d-none');

                if (remaining < 0) {
                    hint.innerHTML = `<span class="text-danger">Exceeds balance by ${((-remaining) / 100000000).toFixed(8)} BTC</span>`;
                } else if (!amountInput?.value) {
                    hint.textContent = `Available: ${(totalSelectedSats / 100000000).toFixed(8)} BTC`;
                } else {
                    hint.textContent = `Remaining: ${(remaining / 100000000).toFixed(8)} BTC`;
                }
            });
        }

        // Get outputs from form
        function getOutputs() {
            const outputs = [];
            const rows = outputsContainer.querySelectorAll('.output-row');

            rows.forEach((row, i) => {
                const destInput = row.querySelector('.destination-input');
                const amountInput = row.querySelector('.amount-input');

                outputs.push({
                    destination: destInput?.value?.trim() || '',
                    amountBtc: amountInput?.value ? parseFloat(amountInput.value) : null
                });
            });

            return outputs;
        }

        // Detect destination type
        function detectDestinationType(destination) {
            if (!destination) return null;

            const lower = destination.toLowerCase();
            if (lower.startsWith('ln') || lower.startsWith('lightning:')) {
                return 'LightningInvoice';
            }
            if (lower.startsWith('bitcoin:') || lower.startsWith('ark:')) {
                return 'Bip21Uri';
            }
            // LNURL or Lightning Address (email format)
            if (lower.startsWith('lnurl') || /^[^@@\s]+@@[^@@\s]+\.[^@@\s]+$/.test(destination)) {
                return 'LnurlPay';
            }
            // Ark addresses start with ark1/tark1
            if (lower.startsWith('ark1') || lower.startsWith('tark1')) {
                return 'ArkAddress';
            }
            // Bitcoin on-chain addresses (requires batch/collab exit)
            if (/^(1|3|bc1|tb1|bcrt1)[a-zA-HJ-NP-Z0-9]+$/.test(destination)) {
                return 'BitcoinAddress';
            }
            return null;
        }

        // Update destination badges
        function updateDestinationBadges() {
            const rows = outputsContainer.querySelectorAll('.output-row');
            let hasLightning = false;
            let hasBitcoinAddress = false;
            let filledDestCount = 0;

            rows.forEach((row, i) => {
                const destInput = row.querySelector('.destination-input');
                const badge = row.querySelector('.destination-type-badge');
                const removeBtn = row.querySelector('.remove-output-btn');
                const type = detectDestinationType(destInput?.value);

                if (destInput?.value?.trim()) filledDestCount++;
                if (type === 'LightningInvoice' || type === 'LnurlPay') hasLightning = true;
                if (type === 'BitcoinAddress') hasBitcoinAddress = true;

                if (badge) {
                    const badgeMap = {
                        'ArkAddress': ['Arkade', 'bg-success'],
                        'LightningInvoice': ['Lightning', 'text-bg-warning'],
                        'LnurlPay': ['LNURL', 'bg-info'],
                        'Bip21Uri': ['BIP21', 'bg-info'],
                        'BitcoinAddress': ['Bitcoin (Batch)', 'bg-primary'],
                    };
                    const [label, cls] = badgeMap[type] || ['', 'bg-secondary'];
                    badge.textContent = label;
                    badge.className = 'destination-type-badge badge ' + (label ? cls : '');
                }

                // Hide remove button on the only row if it's empty
                if (removeBtn) {
                    const isOnlyRow = rows.length === 1;
                    const isEmpty = !destInput?.value?.trim();
                    removeBtn.style.display = (isOnlyRow && isEmpty) ? 'none' : '';
                }
            });

            state.isLightning = hasLightning;
            state.hasBitcoinAddress = hasBitcoinAddress;

            // Lightning swap constraints
            if (addOutputBtn) {
                addOutputBtn.disabled = hasLightning;
                addOutputBtn.title = hasLightning ? 'Lightning swaps support single output only' : '';
                addOutputBtn.style.display = hasLightning ? 'none' : '';
            }

            // Update spend type constraints (Lightning hides it, Bitcoin forces Batch)
            updateSpendTypeSection();

            // Show error if Lightning with multiple destinations
            const lightningError = document.getElementById('lightning-multi-dest-error');
            if (hasLightning && filledDestCount > 1) {
                if (!lightningError) {
                    const errorDiv = document.createElement('div');
                    errorDiv.id = 'lightning-multi-dest-error';
                    errorDiv.className = 'alert alert-danger mt-2';
                    errorDiv.textContent = 'Lightning swaps only support a single destination. Remove extra destinations to continue.';
                    outputsContainer.parentNode.insertBefore(errorDiv, outputsContainer.nextSibling);
                }
                sendBtn.disabled = true;
            } else if (lightningError) {
                lightningError.remove();
            }
        }

        // Estimate fees
        const estimateFees = debounce(async function() {
            const selectedCoins = getSelectedCoins();
            const outputs = getOutputs();
            const hasDestinations = outputs.some(o => o.destination);
            const isAuto = state.coinSelectionMode === 'auto';

            if (!selectedCoins.length && !isAuto) {
                sendBtn.disabled = true;
                updateReviewContent('Select coins to continue.');
                return;
            }

            // Calculate total input from checked coins
            let totalInputSats = 0;
            coinsTable.querySelectorAll('.coin-checkbox:checked').forEach(cb => {
                const row = cb.closest('tr');
                const amountText = row.cells[2].textContent;
                totalInputSats += Math.round(parseFloat(amountText) * 100000000);
            });

            try {
                const response = await fetch(`/plugins/ark/stores/@Model.StoreId/estimate-fees`, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]')?.value
                    },
                    body: JSON.stringify({
                        vtxoOutpoints: selectedCoins,
                        totalInputSats: totalInputSats,
                        coinSelectionMode: state.coinSelectionMode,
                        spendType: state.userSpendType,
                        outputs: outputs.filter(o => o.destination).map(o => ({
                            destination: o.destination,
                            amountSats: o.amountBtc ? Math.round(o.amountBtc * 100000000) : null
                        }))
                    })
                });

                const data = await response.json();

                if (data.error) {
                    state.pendingMaxAdjustment = null;
                    sendBtn.disabled = true;
                    updateReviewContent(data.error);
                } else {
                    state.estimatedFee = data.estimatedFeeSats;
                    sendBtn.disabled = false;

                    // Apply pending "Max" adjustment: when the user clicked
                    // Max we filled the gross balance so the fee estimator
                    // had a real output to price; now we know the fee, so
                    // revise the amount down to (gross − fee). For Arkade
                    // (offchain) sends the fee is 0 — nothing to subtract.
                    if (state.pendingMaxAdjustment !== null) {
                        const adj = state.pendingMaxAdjustment;
                        state.pendingMaxAdjustment = null;
                        if (data.estimatedFeeSats && data.estimatedFeeSats > 0) {
                            const adjRow = outputsContainer.querySelector(`.output-row[data-index="${adj.index}"]`);
                            const adjInput = adjRow?.querySelector('.amount-input');
                            if (adjInput && !adjInput.readOnly) {
                                const netSats = Math.max(0, adj.grossSats - data.estimatedFeeSats);
                                adjInput.value = (netSats / 100000000).toFixed(8);
                                updateRemainingBalance();
                            }
                        }
                    }

                    // In auto mode, sync coin checkboxes from server selection
                    if (isAuto && data.selectedOutpoints?.length) {
                        const serverSelected = new Set(data.selectedOutpoints);
                        coinsTable.querySelectorAll('.coin-checkbox').forEach(cb => {
                            cb.checked = serverSelected.has(cb.value);
                        });
                        updateCoinsSummary();
                        updateRemainingBalance();
                    }

                    // Mark consolidation for review display
                    if (!hasDestinations) data.isConsolidation = true;

                    // Use server-reported coins for review if auto
                    const reviewCoins = (isAuto && data.selectedOutpoints?.length)
                        ? data.selectedOutpoints
                        : selectedCoins;

                    updateReviewSection(reviewCoins, outputs, data);
                }
            } catch (err) {
                state.pendingMaxAdjustment = null;
                console.error('Fee estimation failed:', err);
                sendBtn.disabled = true;
                updateReviewContent('Error estimating fee');
            }
        }, 500);

        // Helper to update review content with a message
        function updateReviewContent(message) {
            reviewSummary.textContent = '';
            reviewContent.innerHTML = `<p class="text-muted">${message}</p>`;
        }

        // Check if any selected coins are recoverable (batch-only)
        function hasRecoverableCoins() {
            const checkboxes = coinsTable.querySelectorAll('.coin-checkbox:checked');
            for (const cb of checkboxes) {
                const row = cb.closest('tr');
                const badge = row.querySelector('[data-coin-type]');
                if (badge && badge.dataset.coinType === 'recoverable') {
                    return true;
                }
            }
            return false;
        }

        // Update spend type section summary
        function updateSpendTypeSection() {
            // Hide for Lightning (type is determined by destination)
            if (state.isLightning) {
                spendTypeSection.style.display = 'none';
                return;
            }
            // Force Batch for Bitcoin on-chain addresses
            if (state.hasBitcoinAddress) {
                spendTypeSection.style.display = '';
                if (spendTypeBatch) spendTypeBatch.checked = true;
                if (spendTypeArkade) { spendTypeArkade.checked = false; spendTypeArkade.disabled = true; }
                if (!state._savedSpendType) state._savedSpendType = state.userSpendType;
                var wasAlreadyBatch = state.userSpendType === 'Batch';
                state.userSpendType = 'Batch';
                spendTypeSummary.textContent = 'Batch (required for on-chain address)';
                // Re-select coins for Batch mode if switching from Arkade
                if (!wasAlreadyBatch && state.coinSelectionMode === 'auto') {
                    const outputs = getOutputs();
                    const amounts = outputs.filter(o => o.destination).map(o => o.amountBtc ? Math.round(o.amountBtc * 100000000) : null);
                    const totalNeeded = amounts.every(a => a !== null) ? amounts.reduce((sum, a) => sum + a, 0) : null;
                    autoSelectCoins(totalNeeded);
                    handleCoinSelectionChange();
                }
                return;
            }
            spendTypeSection.style.display = '';
            if (spendTypeArkade) spendTypeArkade.disabled = false;
            // Restore previous spend type if it was overridden by Bitcoin address
            if (state._savedSpendType) {
                state.userSpendType = state._savedSpendType;
                delete state._savedSpendType;
                const radio = state.userSpendType === 'Batch' ? spendTypeBatch : spendTypeArkade;
                if (radio) radio.checked = true;
            }
            spendTypeSummary.textContent = state.userSpendType;
        }

        // Get coins sorted by expiry (closest first)
        function getCoinsSortedByExpiry() {
            const rows = Array.from(coinsTable.querySelectorAll('tbody tr'));
            return rows.sort((a, b) => {
                const expiryA = a.querySelector('.vtxo-expiry')?.dataset.expires || Infinity;
                const expiryB = b.querySelector('.vtxo-expiry')?.dataset.expires || Infinity;
                return parseFloat(expiryA) - parseFloat(expiryB);
            });
        }

        // Auto-select coins based on spend type and amount needed
        function autoSelectCoins(amountNeededSats = null) {
            if (state.coinSelectionMode !== 'auto') return;

            const rows = coinsTable.querySelectorAll('tbody tr');
            let selectedSats = 0;

            if (state.userSpendType === 'Arkade') {
                // Arkade: only select non-recoverable (spendable) coins
                rows.forEach(row => {
                    const badge = row.querySelector('[data-coin-type]');
                    const cb = row.querySelector('.coin-checkbox');
                    if (!badge || !cb) return;
                    cb.checked = (badge.dataset.coinType === 'spendable');
                    if (cb.checked) {
                        const amountText = row.cells[2].textContent;
                        selectedSats += Math.round(parseFloat(amountText) * 100000000);
                    }
                });
            } else {
                // Batch: select all coins (recoverable + spendable)
                // When no amount specified, select everything (send-all or consolidation)
                // When amount specified, select recoverable first then add spendable until enough
                rows.forEach(row => {
                    const badge = row.querySelector('[data-coin-type]');
                    const cb = row.querySelector('.coin-checkbox');
                    if (!badge || !cb) return;
                    const coinType = badge.dataset.coinType;
                    const amountText = row.cells[2].textContent;
                    const coinSats = Math.round(parseFloat(amountText) * 100000000);

                    if (!amountNeededSats) {
                        // No specific amount — select all coins
                        cb.checked = true;
                    } else {
                        // Prefer recoverable first
                        cb.checked = (coinType === 'recoverable');
                    }
                    if (cb.checked) selectedSats += coinSats;
                });

                // If amount specified and recoverable coins weren't enough, add spendable
                if (amountNeededSats && selectedSats < amountNeededSats) {
                    const sortedRows = getCoinsSortedByExpiry();
                    for (const row of sortedRows) {
                        if (selectedSats >= amountNeededSats) break;
                        const badge = row.querySelector('[data-coin-type]');
                        const cb = row.querySelector('.coin-checkbox');
                        if (!badge || !cb || cb.checked) continue;
                        if (badge.dataset.coinType === 'spendable') {
                            const amountText = row.cells[2].textContent;
                            const coinSats = Math.round(parseFloat(amountText) * 100000000);
                            cb.checked = true;
                            selectedSats += coinSats;
                        }
                    }
                }
            }

            updateCoinsSummary();
        }

        // Get the effective spend type based on conditions and user choice
        function getEffectiveSpendType(needsRecovery) {
            if (needsRecovery) return 'Batch (Recovery)';
            if (state.isLightning) return 'Lightning Swap';
            if (state.hasBitcoinAddress) return 'Batch';
            return state.userSpendType;
        }

        // Check for pointless 1-in-1-out Arkade consolidation
        function isPointlessArkadeConsolidation(coinsCount, hasDestinations, needsRecovery) {
            // Arkade mode, no destination (consolidation), single non-recoverable coin = pointless
            return !hasDestinations &&
                   coinsCount === 1 &&
                   !needsRecovery &&
                   state.userSpendType === 'Arkade';
        }

        // Update review section
        function updateReviewSection(coins, outputs, feeData) {
            const totalInput = coins.length;
            const totalOutputs = outputs.filter(o => o.destination).length;
            const isConsolidation = totalOutputs === 0;
            const needsRecovery = hasRecoverableCoins();

            // Update spend type section
            updateSpendTypeSection();

            const spendType = getEffectiveSpendType(needsRecovery);

            // Check for pointless 1-in-1-out Arkade consolidation
            if (isPointlessArkadeConsolidation(totalInput, !isConsolidation, needsRecovery)) {
                sendBtn.disabled = true;
                reviewSummary.innerHTML = '<span class="text-warning">1-in-1-out not useful</span>';
                reviewContent.innerHTML = `
                    <div class="alert alert-warning mb-0">
                        <strong>Not useful:</strong> Arkade consolidation with a single coin doesn't accomplish anything.
                        <ul class="mb-0 mt-2">
                            <li>Select multiple coins to consolidate them into one</li>
                            <li>Use <strong>Batch</strong> mode to renew your coin's expiry</li>
                            <li>Enter a destination to send funds somewhere</li>
                        </ul>
                    </div>`;
                return;
            }

            reviewSummary.textContent = isConsolidation
                ? `Consolidating ${totalInput} coin(s)`
                : `${totalOutputs} output(s) via ${spendType}`;

            let html = '<dl class="row mb-0">';
            html += `<dt class="col-sm-4">Inputs</dt><dd class="col-sm-8">${totalInput} coin(s)</dd>`;
            html += `<dt class="col-sm-4">Outputs</dt><dd class="col-sm-8">${totalOutputs}</dd>`;
            html += `<dt class="col-sm-4">Spend Type</dt><dd class="col-sm-8"><span class="badge text-bg-primary">${spendType}</span></dd>`;
            html += `<dt class="col-sm-4">Fee</dt><dd class="col-sm-8">`;
            if (feeData.estimatedFeeSats !== null && feeData.estimatedFeeSats > 0) {
                html += `<strong>${feeData.estimatedFeeSats.toLocaleString()} sats</strong>`;
                if (feeData.feeDescription) {
                    html += `<br><span class="text-muted small">${feeData.feeDescription}</span>`;
                }
                if (feeData.isLightning) {
                    html += `<br><span class="text-muted small">`;
                    html += `Service: ${feeData.feePercentage.toFixed(2)}%`;
                    html += ` + Miner: ${feeData.minerFeeSats} sats`;
                    html += `</span>`;
                }
            } else {
                html += `<span class="text-success">0 sats (no fee)</span>`;
            }
            html += `</dd>`;
            html += '</dl>';

            reviewContent.innerHTML = html;
        }

        // Suggest coins based on destination
        async function suggestCoins() {
            if (state.coinSelectionMode !== 'auto') return;

            const outputs = getOutputs().filter(o => o.destination);
            if (!outputs.length) return;

            const firstDest = outputs[0].destination;
            const destType = detectDestinationType(firstDest);
            if (!destType) return;

            // Calculate total amount needed
            let totalSats = null;
            const amounts = outputs.map(o => o.amountBtc ? Math.round(o.amountBtc * 100000000) : null);
            if (amounts.every(a => a !== null)) {
                totalSats = amounts.reduce((sum, a) => sum + a, 0);
            }

            try {
                const response = await fetch(`/plugins/ark/stores/@Model.StoreId/suggest-coins`, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]')?.value
                    },
                    body: JSON.stringify({
                        destinationType: destType,
                        amountSats: totalSats
                    })
                });

                const data = await response.json();

                if (!data.error && data.suggestedOutpoints?.length) {
                    // Select suggested coins
                    const suggested = new Set(data.suggestedOutpoints);
                    coinsTable.querySelectorAll('.coin-checkbox').forEach(cb => {
                        cb.checked = suggested.has(cb.value);
                    });

                    state.detectedSpendType = data.spendType;
                    updateCoinsSummary();
                    estimateFees();
                }
            } catch (err) {
                console.error('Coin suggestion failed:', err);
            }
        }

        // Add output row
        function addOutputRow() {
            const index = outputsContainer.querySelectorAll('.output-row').length;
            const scanIcon = document.querySelector('.scan-qr-btn svg')?.outerHTML || '&#x1F4F7;';
            const template = `
                <div class="output-row" data-index="${index}">
                    <div class="row g-3">
                        <div class="col-12 col-md-7">
                            <label class="form-label">Address, Invoice, or BIP21</label>
                            <div class="input-group">
                                <input type="text"
                                       name="Outputs[${index}].Destination"
                                       class="form-control destination-input"
                                       placeholder="Paste address, invoice, or BIP21 URI..."
                                       data-index="${index}" />
                                <button type="button"
                                        class="btn btn-secondary px-3 only-for-js scan-qr-btn"
                                        data-index="${index}"
                                        title="Scan QR code">
                                    ${scanIcon}
                                </button>
                            </div>
                        </div>
                        <div class="col-12 col-md-3">
                            <label class="form-label">Amount (BTC)</label>
                            <div class="input-group">
                                <input type="number"
                                       name="Outputs[${index}].AmountBtc"
                                       class="form-control amount-input"
                                       placeholder="Optional"
                                       step="0.00000001"
                                       min="0"
                                       data-index="${index}" />
                                <button type="button" class="btn btn-outline-secondary max-amount-btn" data-index="${index}" title="Fill remaining balance">Max</button>
                            </div>
                            <small class="remaining-balance-hint text-muted d-none mt-1"></small>
                        </div>
                        <div class="col-12 col-md-1 d-flex align-items-center" style="margin-top: 1.75rem;">
                            <button type="button" class="btn btn-link text-danger remove-output-btn p-0" data-index="${index}" title="Remove destination">
                                <svg role="img" class="icon icon-cross"><use href="/img/icon-sprite.svg#cross"></use></svg>
                            </button>
                        </div>
                    </div>
                    <input type="hidden" name="Outputs[${index}].PayoutId" value="" />
                    <input type="hidden" name="Outputs[${index}].IsReadonly" value="false" />
                    <input type="hidden" name="Outputs[${index}].IsBip21Parsed" value="false" />
                    <div class="mt-2 d-flex align-items-center gap-2">
                        <span class="destination-type-badge badge" data-index="${index}"></span>
                    </div>
                </div>
            `;
            outputsContainer.insertAdjacentHTML('beforeend', template);
        }

        // Remove output row and reindex
        function removeOutputRow(index) {
            const rows = outputsContainer.querySelectorAll('.output-row');
            const row = outputsContainer.querySelector(`.output-row[data-index="${index}"]`);
            if (!row) return;

            if (rows.length <= 1) {
                // Last row — reset it instead of removing
                const destInput = row.querySelector('.destination-input');
                const amountInput = row.querySelector('.amount-input');
                if (destInput) { destInput.value = ''; destInput.readOnly = false; }
                if (amountInput) { amountInput.value = ''; amountInput.readOnly = false; amountInput.placeholder = 'Optional'; amountInput.removeAttribute('min'); amountInput.removeAttribute('max'); }
                row.querySelector('.bip21-display')?.remove();
                row.querySelector('.lnurl-range-hint')?.remove();
                row.querySelector('.payout-badge')?.remove();
                row.querySelector('.text-danger.small')?.remove();
                row.querySelectorAll('input[type="hidden"]').forEach(h => h.value = '');
                const badge = row.querySelector('.destination-type-badge');
                if (badge) { badge.textContent = ''; badge.className = 'destination-type-badge badge'; }
            } else {
                row.remove();
                reindexOutputs();
            }

            updateDestinationBadges();
            estimateFees();
        }

        // Reindex output rows after removal
        function reindexOutputs() {
            const rows = outputsContainer.querySelectorAll('.output-row');
            rows.forEach((row, i) => {
                row.dataset.index = i;
                row.querySelectorAll('[data-index]').forEach(el => el.dataset.index = i);
                row.querySelectorAll('[name*="Outputs["]').forEach(input => {
                    input.name = input.name.replace(/Outputs\[\d+\]/, `Outputs[${i}]`);
                });
            });
        }

        // Helper to handle coin selection changes (consolidation vs destination mode)
        function handleCoinSelectionChange() {
            const selectedCoins = getSelectedCoins();

            updateRemainingBalance();

            if (selectedCoins.length === 0 && state.coinSelectionMode !== 'auto') {
                sendBtn.disabled = true;
                updateReviewContent('Select coins to continue.');
            } else {
                // Always estimate fees — in auto mode, server picks coins
                estimateFees();
            }
        }

        // === BIP21/Destination parsing via AJAX ===

        function escapeHtml(text) {
            const div = document.createElement('div');
            div.textContent = text;
            return div.innerHTML;
        }

        function updateHiddenField(row, fieldName, value) {
            let input = row.querySelector(`input[name*=".${fieldName}"]`);
            if (!input) {
                input = document.createElement('input');
                input.type = 'hidden';
                const index = row.dataset.index;
                input.name = `Outputs[${index}].${fieldName}`;
                row.appendChild(input);
            }
            input.value = value;
        }

        function insertBip21Display(row, rawBip21) {
            if (row.querySelector('.bip21-display')) return;
            const html = `
                <div class="mb-2 bip21-display">
                    <label class="form-label text-muted small">BIP21 URI</label>
                    <input type="text" class="form-control form-control-sm font-monospace"
                           value="${escapeHtml(rawBip21)}" readonly />
                </div>`;
            const rowG3 = row.querySelector('.row.g-3');
            if (rowG3) rowG3.insertAdjacentHTML('beforebegin', html);
        }

        function insertLnurlRangeHint(row, minSats, maxSats) {
            row.querySelector('.lnurl-range-hint')?.remove();
            const hint = document.createElement('small');
            hint.className = 'lnurl-range-hint text-muted d-block mt-1';
            hint.textContent = `Amount range: ${minSats.toLocaleString()} \u2013 ${maxSats.toLocaleString()} sats`;
            const amountCol = row.querySelector('.amount-input')?.closest('.col-md-3');
            if (amountCol) amountCol.appendChild(hint);
        }

        function insertPayoutBadge(row, payoutId) {
            const badgeArea = row.querySelector('.mt-2.d-flex');
            if (!badgeArea || badgeArea.querySelector('.payout-badge')) return;
            const badge = document.createElement('span');
            badge.className = 'badge bg-info payout-badge';
            badge.textContent = 'Fulfilling payout';
            badgeArea.appendChild(badge);
        }

        function updateOutputError(index, error) {
            const row = outputsContainer.querySelector(`.output-row[data-index="${index}"]`);
            if (!row) return;
            let errorDiv = row.querySelector('.text-danger.small');
            if (error) {
                if (!errorDiv) {
                    const inputGroup = row.querySelector('.input-group') || row.querySelector('.destination-input');
                    errorDiv = document.createElement('div');
                    errorDiv.className = 'text-danger small mt-1';
                    inputGroup.parentNode.appendChild(errorDiv);
                }
                errorDiv.textContent = error;
            } else if (errorDiv) {
                errorDiv.remove();
            }
        }

        function setDestinationLoading(index, loading) {
            const row = outputsContainer.querySelector(`.output-row[data-index="${index}"]`);
            if (!row) return;
            const destInput = row.querySelector('.destination-input');
            const badge = row.querySelector('.destination-type-badge');
            if (loading) {
                destInput?.classList.add('opacity-50');
                destInput?.setAttribute('disabled', '');
                if (badge) {
                    badge.textContent = 'Resolving\u2026';
                    badge.className = 'destination-type-badge badge text-bg-secondary';
                }
            } else {
                destInput?.classList.remove('opacity-50');
                destInput?.removeAttribute('disabled');
                // Reset badge if it still says "Resolving…" (e.g. after error or clear)
                if (badge && badge.textContent === 'Resolving\u2026') {
                    badge.textContent = '';
                    badge.className = 'destination-type-badge badge';
                }
            }
        }

        async function parseDestination(index, destination) {
            if (!destination || destination.trim() === '') return;

            setDestinationLoading(index, true);
            try {
                // Include current amount from the form so the server can validate properly
                const row = outputsContainer.querySelector(`.output-row[data-index="${index}"]`);
                const amountVal = row?.querySelector('.amount-input')?.value;
                const amountBtc = amountVal ? parseFloat(amountVal) : null;

                const response = await fetch(`/plugins/ark/stores/@Model.StoreId/parse-destination`, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]')?.value
                    },
                    body: JSON.stringify({ destination: destination.trim(), amountBtc: amountBtc })
                });

                const data = await response.json();
                if (!data.isValid) {
                    setDestinationLoading(index, false);
                    updateOutputError(index, data.error);
                    return;
                }

                if (!row) return;

                const destInput = row.querySelector('.destination-input');
                const amountInput = row.querySelector('.amount-input');
                const badge = row.querySelector('.destination-type-badge');

                // Clear previous error
                updateOutputError(index, null);

                // If BIP21, make readonly and show raw URI
                if (data.isBip21) {
                    destInput.value = data.resolvedAddress || destination;
                    destInput.readOnly = true;
                    insertBip21Display(row, destination);
                    updateHiddenField(row, 'IsReadonly', 'true');
                    updateHiddenField(row, 'IsBip21Parsed', 'true');
                    updateHiddenField(row, 'RawBip21', destination);
                }

                // LNURL / Lightning Address: destination readonly, amount editable with range
                if (data.isLnurl) {
                    destInput.readOnly = true;
                    updateHiddenField(row, 'IsReadonly', 'true');

                    // Amount is editable — user must choose within range
                    amountInput.readOnly = false;
                    if (data.lnurlMinSats > 0 && data.lnurlMaxSats > 0) {
                        const minBtc = (data.lnurlMinSats / 100000000).toFixed(8);
                        const maxBtc = (data.lnurlMaxSats / 100000000).toFixed(8);
                        amountInput.min = minBtc;
                        amountInput.max = maxBtc;
                        amountInput.placeholder = `${data.lnurlMinSats.toLocaleString()} - ${data.lnurlMaxSats.toLocaleString()} sats`;
                        insertLnurlRangeHint(row, data.lnurlMinSats, data.lnurlMaxSats);
                    }
                }
                // Lightning invoices (BOLT11): make destination and amount readonly
                else if (data.isLightning && !data.isBip21) {
                    destInput.readOnly = true;
                    updateHiddenField(row, 'IsReadonly', 'true');
                }

                // Populate amount if parsed from BIP21/invoice (not LNURL — user picks amount)
                if (!data.isLnurl && data.amountSats > 0 && !amountInput.value) {
                    amountInput.value = data.amountBtc.toFixed(8);
                    if (data.isBip21 || data.isLightning) amountInput.readOnly = true;
                }

                // Set payout ID if present
                if (data.payoutId) {
                    updateHiddenField(row, 'PayoutId', data.payoutId);
                    insertPayoutBadge(row, data.payoutId);
                }

                // Update type badge
                if (badge) {
                    badge.textContent = data.typeBadge || '';
                    badge.className = 'destination-type-badge badge ' + (data.typeBadgeClass || 'bg-secondary');
                }

                // Update state and trigger coin suggestion / fee estimation
                setDestinationLoading(index, false);
                state.isLightning = data.isLightning;
                updateDestinationBadges();
                await suggestCoins();
                handleCoinSelectionChange();
            } catch (err) {
                setDestinationLoading(index, false);
                console.error('Destination parse failed:', err);
            }
        }

        // Event listeners

        // Quick select buttons
        selectActiveBtn?.addEventListener('click', function(e) {
            e.stopPropagation();
            selectCoinsByType('spendable');
        });

        selectRecoverableBtn?.addEventListener('click', function(e) {
            e.stopPropagation();
            selectCoinsByType('recoverable');
        });

        addOutputBtn?.addEventListener('click', addOutputRow);

        outputsContainer?.addEventListener('click', function(e) {
            const removeBtn = e.target.closest('.remove-output-btn');
            if (removeBtn) {
                removeOutputRow(parseInt(removeBtn.dataset.index));
                return;
            }
            const scanBtn = e.target.closest('.scan-qr-btn');
            if (scanBtn) {
                window._scanTargetIndex = parseInt(scanBtn.dataset.index);
                var modalEl = document.getElementById('scanModal');
                if (modalEl) {
                    var modal = bootstrap.Modal.getOrCreateInstance(modalEl);
                    modal.show();
                }
                return;
            }
            const maxBtn = e.target.closest('.max-amount-btn');
            if (maxBtn) {
                const index = parseInt(maxBtn.dataset.index);
                const row = outputsContainer.querySelector(`.output-row[data-index="${index}"]`);
                const amountInput = row?.querySelector('.amount-input');
                if (!amountInput || amountInput.readOnly) return;

                let totalSelectedSats = 0;
                coinsTable.querySelectorAll('.coin-checkbox:checked').forEach(cb => {
                    const tr = cb.closest('tr');
                    totalSelectedSats += Math.round(parseFloat(tr.cells[2].textContent) * 100000000);
                });

                let otherAllocated = 0;
                outputsContainer.querySelectorAll('.output-row').forEach(r => {
                    const ai = r.querySelector('.amount-input');
                    if (ai && ai !== amountInput && ai.value) {
                        otherAllocated += Math.round(parseFloat(ai.value) * 100000000);
                    }
                });

                const remaining = totalSelectedSats - otherAllocated;
                if (remaining > 0) {
                    // Mark this output for fee-aware Max adjustment. The fee
                    // estimator runs on the dispatched 'input' event below;
                    // when it returns, the response handler reads this flag
                    // and revises the value to (gross − estimated fee).
                    state.pendingMaxAdjustment = { index, grossSats: remaining };
                    amountInput.value = (remaining / 100000000).toFixed(8);
                    amountInput.dispatchEvent(new Event('input', { bubbles: true }));
                }
            }
        });

        outputsContainer?.addEventListener('input', debounce(function(e) {
            // Dismiss server-rendered error alert on any form interaction
            const serverAlert = document.getElementById('server-errors-alert');
            if (serverAlert) serverAlert.remove();

            if (e.target.classList.contains('destination-input')) {
                const index = parseInt(e.target.dataset.index);
                const value = e.target.value.trim();

                // Clear previous error and badge on any destination edit
                updateOutputError(index, null);
                setDestinationLoading(index, false);

                // Server-side parse for BIP21, Lightning, Ark addresses, LNURL, and Lightning Addresses
                if (value.startsWith('bitcoin:') || value.startsWith('ln') ||
                    value.startsWith('lightning:') || value.startsWith('ark1') ||
                    value.startsWith('tark1') || value.startsWith('lnurl') ||
                    /^[^@@\s]+@@[^@@\s]+\.[^@@\s]+$/.test(value)) {
                    parseDestination(index, value);
                } else {
                    updateDestinationBadges();
                    suggestCoins();
                }
            } else if (e.target.classList.contains('amount-input')) {
                // Clear error from previous validation (e.g. "Amount is required")
                const row = e.target.closest('.output-row');
                if (row) updateOutputError(parseInt(row.dataset.index), null);
                updateRemainingBalance();
                estimateFees();
            }
        }, 500));

        coinsTable?.addEventListener('change', function(e) {
            if (e.target.classList.contains('coin-checkbox')) {
                setCoinSelectionMode('manual');
                updateCoinsSummary();
                handleCoinSelectionChange();
            }
        });

        selectAllCoins?.addEventListener('change', function() {
            selectAllCoinsVisible(this.checked);
            setCoinSelectionMode('manual');
            updateCoinsSummary();
            handleCoinSelectionChange();
        });

        // Reset to auto coin selection
        resetToAutoBtn?.addEventListener('click', function(e) {
            e.stopPropagation(); // Don't toggle section collapse
            setCoinSelectionMode('auto');

            // Clear all coin selections first
            coinsTable.querySelectorAll('.coin-checkbox').forEach(cb => cb.checked = false);
            if (selectAllCoins) selectAllCoins.checked = false;

            // Re-trigger auto selection based on spend type and destination
            const outputs = getOutputs();
            const hasDestinations = outputs.some(o => o.destination);

            if (hasDestinations) {
                // Calculate amount needed for destination-based selection
                const amounts = outputs.filter(o => o.destination).map(o => o.amountBtc ? Math.round(o.amountBtc * 100000000) : null);
                const totalNeeded = amounts.every(a => a !== null) ? amounts.reduce((sum, a) => sum + a, 0) : null;
                autoSelectCoins(totalNeeded);
                handleCoinSelectionChange();
            } else {
                // No destination - auto select based on spend type
                autoSelectCoins();
                handleCoinSelectionChange();
            }
        });

        // Spend type selection - triggers auto coin re-selection
        spendTypeArkade?.addEventListener('change', function() {
            if (this.checked) {
                state.userSpendType = 'Arkade';
                spendTypeSummary.textContent = 'Arkade';

                // Re-select coins based on new spend type if in auto mode
                if (state.coinSelectionMode === 'auto') {
                    const outputs = getOutputs();
                    const amounts = outputs.filter(o => o.destination).map(o => o.amountBtc ? Math.round(o.amountBtc * 100000000) : null);
                    const totalNeeded = amounts.every(a => a !== null) ? amounts.reduce((sum, a) => sum + a, 0) : null;
                    autoSelectCoins(totalNeeded);
                }
                handleCoinSelectionChange();
            }
        });

        spendTypeBatch?.addEventListener('change', function() {
            if (this.checked) {
                state.userSpendType = 'Batch';
                spendTypeSummary.textContent = 'Batch';

                // Re-select coins based on new spend type if in auto mode
                if (state.coinSelectionMode === 'auto') {
                    const outputs = getOutputs();
                    const amounts = outputs.filter(o => o.destination).map(o => o.amountBtc ? Math.round(o.amountBtc * 100000000) : null);
                    const totalNeeded = amounts.every(a => a !== null) ? amounts.reduce((sum, a) => sum + a, 0) : null;
                    autoSelectCoins(totalNeeded);
                }
                handleCoinSelectionChange();
            }
        });

        // Initialize
        updateDestinationBadges();
        updateSpendTypeSection();

        // Check for pre-selected coins or auto-select based on mode
        const preselectedCoins = getSelectedCoins();
        const outputs = getOutputs();
        const hasDestinations = outputs.some(o => o.destination);

        if (preselectedCoins.length > 0) {
            // Pre-selected coins (manual mode from URL params)
            updateCoinsSummary();
            estimateFees();
        } else if (state.coinSelectionMode === 'auto') {
            // Auto mode - server will select coins; try local selection too for UI
            autoSelectCoins();
            updateCoinsSummary();
            estimateFees();
        } else {
            updateCoinsSummary();
        }
    })();

    // Initialize QR scanner (after Vue.js loads)
    window.addEventListener('load', function() {
        if (typeof initCameraScanningApp === 'function') {
            initCameraScanningApp('Scan address or payment link', function(data) {
                var targetIndex = window._scanTargetIndex || 0;
                var destInput = document.querySelector(
                    '.destination-input[data-index="' + targetIndex + '"]');
                if (destInput && !destInput.readOnly) {
                    destInput.value = data;
                    destInput.dispatchEvent(new Event('input', { bubbles: true }));
                }
            }, 'scanModal', false);
        }
    });
    </script>
}
