@using BTCPayServer.Abstractions.Contracts
@using BTCPayServer.Abstractions.Extensions
@using BTCPayServer.Plugins.ArkPayServer.Helpers
@using NArk.Abstractions.Wallets
@using NArk.Abstractions.Intents
@using NArk.Swaps.Models
@using NBitcoin
@model BTCPayServer.Plugins.ArkPayServer.Models.StoreOverviewViewModel
@inject IScopeProvider ScopeProvider
@inject ArkNetworkConfig ArkNetworkConfig

@{
    ViewData.SetActivePage(category: "Ark", activePage: "StoreOverview", title: "Arkade - Overview");
    var storeId = ScopeProvider.GetCurrentStoreId();
}

<partial name="_StatusMessage" />

<!-- Top Row: Wallet Info + Service Status -->
<div class="row g-4 mb-4">
    <!-- Wallet Info Tile -->
    <div class="col-xl-8">
        <div class="bg-tile rounded p-3 p-sm-4 h-100">
            <div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mb-3">
                <h2 class="h5 mb-0">Wallet</h2>
                @if (Model.Balances != null)
                {
                    <partial name="_ArkBalances" model="Model.Balances" view-data='new ViewDataDictionary(ViewData) { { "CompactMode", true }, { "NoContainer", true } }' />
                }
            </div>

            <!-- Receive Address -->
            @if (!string.IsNullOrEmpty(Model.DefaultAddress) && Model.WalletType == WalletType.SingleKey)
            {
                <div class="mb-3">
                    <label class="text-muted small">Receive Address</label>
                    <div class="input-group input-group-sm">
                        <input type="text" class="form-control form-control-sm font-monospace" value="@Model.DefaultAddress" readonly data-testid="receive-address" />
                        <button type="button" class="btn btn-outline-secondary btn-sm" data-clipboard="@Model.DefaultAddress" data-testid="copy-address-btn" title="Copy to clipboard">
                            <vc:icon symbol="actions-copy" />
                        </button>
                    </div>
                </div>
            }

            <div class="row g-3">
                <!-- Left Column: Wallet Info -->
                <div class="col-md-6">
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <span class="text-muted">Wallet Type</span>
                        <span class="badge @(Model.WalletType == WalletType.HD ? "text-bg-primary" : "text-bg-secondary")">
                            @(Model.WalletType == WalletType.HD ? "HD (BIP-39)" : "Legacy (nsec)")
                        </span>
                    </div>
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <span class="text-muted">Wallet ID</span>
                        @if (!string.IsNullOrEmpty(Model.WalletId))
                        {
                            <vc:truncate-center text="@Model.WalletId" classes="truncate-center-id"/>
                        }
                    </div>
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <span class="text-muted">Private Keys</span>
                        @if (Model.SignerAvailable)
                        {
                            <span class="badge text-bg-success">Available</span>
                        }
                        else
                        {
                            <span class="badge text-bg-warning">Watch-Only</span>
                        }
                    </div>
                </div>

                <!-- Right Column: Features -->
                <div class="col-md-6">
                    @if (!string.IsNullOrEmpty(Model.BoltzUrl))
                    {
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <span class="text-muted">Lightning</span>
                            <form asp-action="@(Model.IsLightningEnabled ? "DisableLightning" : "EnableLightning")" method="post" asp-route-storeId="@storeId" class="d-inline">
                                <button type="submit" class="btn btn-sm  badge  text-primary @(Model.IsLightningEnabled ? "btn-outline-secondary" : "btn-outline-primary")">
                                    @(Model.IsLightningEnabled ? "Disable" : "Enable")
                                </button>
                            </form>
                        </div>
                    }
                    else
                    {
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <span class="text-muted">Lightning</span>
                            <span class="badge text-bg-secondary" title="Requires a Boltz swap service — configure the Boltz URL in Arkade server settings">Unavailable</span>
                        </div>
                    }

                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <span class="text-muted">Auto-Sweep</span>
                        @if (Model.CanManagePrivateKeys)
                        {
                            <button type="button" class="btn btn-sm badge btn-outline-secondary text-primary"
                                    data-bs-toggle="modal" data-bs-target="#autoSweepModal"
                                    title="@(!string.IsNullOrEmpty(Model.Destination) ? Model.Destination : "Configure auto-sweep destination")">
                                @if (!string.IsNullOrEmpty(Model.Destination))
                                {
                                    <text>Enabled</text>
                                }
                                else
                                {
                                    <text>Configure</text>
                                }
                            </button>
                        }
                        else
                        {
                            @if (!string.IsNullOrEmpty(Model.Destination))
                            {
                                <span class="badge text-bg-info" title="@Model.Destination">Enabled</span>
                            }
                            else
                            {
                                <span class="badge text-bg-secondary">Disabled</span>
                            }
                        }
                    </div>

                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <span class="text-muted">Sub-Dust</span>
                        <form asp-action="UpdateWalletConfig" method="post" asp-route-storeId="@storeId" class="d-inline">
                            <button type="submit" name="command" value="toggle-subdust"
                                    class="btn btn-sm badge text-primary btn-outline-secondary"
                                    @(Model.IsDestinationSweepEnabled && !Model.AllowSubDustAmounts ? "disabled" : "")
                                    title="@(Model.IsDestinationSweepEnabled && !Model.AllowSubDustAmounts ? "Cannot enable while auto-sweep is active — sub-dust VTXOs cannot be swept on-chain" : "Accept payments below the on-chain dust threshold (~330 sats)")">
                                @(Model.AllowSubDustAmounts ? "Enabled" : "Disabled")
                            </button>
                        </form>
                    </div>

                    @if (Model.WalletType == WalletType.HD)
                    {
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <span class="text-muted">Boarding</span>
                            <button type="button" class="btn btn-sm badge btn-outline-secondary text-primary"
                                    data-bs-toggle="modal" data-bs-target="#boardingModal"
                                    title="Include a P2TR on-chain boarding address on invoices when no BTC on-chain payment method is configured">
                                @(Model.BoardingEnabled ? "Enabled" : "Disabled")
                            </button>
                        </div>
                    }

                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <span class="text-muted">Diagnostic Log</span>
                        <a asp-action="DownloadWalletLog" asp-route-storeId="@storeId"
                           class="btn btn-sm badge btn-outline-secondary text-primary"
                           title="Download this wallet's diagnostic log to share with support"
                           data-testid="download-wallet-log-btn">
                            Download
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Service Status Tile -->
    <div class="col-xl-4">
        <div class="bg-tile rounded p-3 p-sm-4 h-100">
            <h2 class="h5 mb-3">Service Status</h2>
            <partial name="_ServiceConnections" model="Model" view-data='new ViewDataDictionary(ViewData) { { "CompactMode", false } }' />
        </div>
    </div>
</div>

<!-- Bottom Row: VTXO List + Quick Actions -->
<div class="row g-4 mb-4">
    <!-- VTXO List Tile -->
    <div class="col-xl-8">
        <div class="bg-tile rounded p-3 p-sm-4 h-100">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h2 class="h5 mb-0">Recent VTXOs</h2>
                <a asp-action="Vtxos" asp-route-storeId="@storeId" class="btn btn-sm btn-outline-secondary">
                    View All (@Model.TotalVtxoCount)
                </a>
            </div>

            <partial name="_VtxoTable" model="Model.RecentVtxos" view-data='new ViewDataDictionary(ViewData) {
                { "ShowAddressColumn", true },
                { "ShowSpendableStatus", true },
                { "CompactMode", true },
                { "VtxoContracts", Model.VtxoContracts },
                { "SpendableOutpoints", Model.SpendableOutpoints }
            }' />
        </div>
    </div>

    <!-- Quick Actions Tile -->
    <div class="col-xl-4">
        <div class="bg-tile rounded p-3 p-sm-4">
            <h2 class="h5 mb-3">Quick Actions</h2>
            <div class="d-grid gap-2">
                @if (Model.CanManagePrivateKeys)
                {
                    <a asp-action="Send" asp-route-storeId="@storeId" class="btn btn-primary" data-testid="send-btn">
                        <vc:icon symbol="actions-send" /> Send
                    </a>
                    <a asp-action="Receive" asp-route-storeId="@storeId" class="btn btn-outline-primary" data-testid="receive-btn">
                        <vc:icon symbol="actions-receive" /> Receive
                    </a>
                }
                <form asp-action="SyncWallet" method="post" asp-route-storeId="@storeId">
                    <button type="submit" class="btn btn-outline-secondary w-100" data-testid="sync-wallet-btn">
                        <vc:icon symbol="actions-refresh" /> Sync Wallet
                    </button>
                </form>
                @if (Model.SignerAvailable && !string.IsNullOrEmpty(Model.Wallet) && Model.CanManagePrivateKeys)
                {
                    <form method="post" asp-controller="Ark" asp-action="ShowPrivateKey" asp-route-storeId="@storeId" style="display:inline">
                        <button type="submit" class="btn btn-outline-secondary w-100" data-testid="show-private-key-btn">
                            <vc:icon symbol="key" /> @(Model.WalletType == WalletType.HD ? "Show Seed" : "Show Key")
                        </button>
                    </form>
                }
                <button type="button" class="btn btn-outline-danger" data-bs-toggle="modal" data-bs-target="#clearWalletModal" data-testid="clear-wallet-btn">
                    <vc:icon symbol="cross" /> Clear Wallet
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Recent Intents + Recent Swaps -->
<div class="row g-4 mb-4">
    <!-- Recent Intents -->
    <div class="col-md-6">
        <div class="bg-tile rounded p-3 p-sm-4 h-100">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h2 class="h5 mb-0">Recent Batches</h2>
                <a asp-action="Intents" asp-route-storeId="@storeId" class="btn btn-sm btn-outline-secondary">
                    View All
                </a>
            </div>
            @if (Model.RecentIntents.Any())
            {
                <div class="table-responsive">
                    <table class="table table-sm mb-0">
                        <thead>
                            <tr>
                                <th text-translate="true">Created</th>
                                <th text-translate="true">State</th>
                                <th text-translate="true">Batch ID</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var intent in Model.RecentIntents)
                            {
                                <tr>
                                    <td>@intent.CreatedAt.ToTimeAgo()</td>
                                    <td>
                                        @switch (intent.State)
                                        {
                                            case ArkIntentState.WaitingToSubmit:
                                                <span class="badge text-bg-secondary">Waiting</span>
                                                break;
                                            case ArkIntentState.WaitingForBatch:
                                                <span class="badge text-bg-warning">Queued</span>
                                                break;
                                            case ArkIntentState.BatchInProgress:
                                                <span class="badge text-bg-primary">In Progress</span>
                                                break;
                                            case ArkIntentState.BatchSucceeded:
                                                <span class="badge text-bg-success">Succeeded</span>
                                                break;
                                            case ArkIntentState.BatchFailed:
                                                <span class="badge text-bg-danger" title="@intent.CancellationReason">Failed</span>
                                                break;
                                            case ArkIntentState.Cancelled:
                                                <span class="badge text-bg-dark" title="@intent.CancellationReason">Cancelled</span>
                                                break;
                                        }
                                    </td>
                                    <td>
                                        @if (!string.IsNullOrEmpty(intent.BatchId))
                                        {
                                            <vc:truncate-center text="@intent.BatchId" classes="truncate-center-id"/>
                                        }
                                        else
                                        {
                                            <span class="text-muted">-</span>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <p class="text-muted text-center mb-0">No batches yet</p>
            }
        </div>
    </div>

    <!-- Recent Swaps -->
    <div class="col-md-6">
        <div class="bg-tile rounded p-3 p-sm-4 h-100">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h2 class="h5 mb-0">Recent Swaps</h2>
                <a asp-action="Swaps" asp-route-storeId="@storeId" class="btn btn-sm btn-outline-secondary">
                    View All
                </a>
            </div>
            @if (Model.RecentSwaps.Any())
            {
                <div class="table-responsive">
                    <table class="table table-sm mb-0">
                        <thead>
                            <tr>
                                <th text-translate="true">Swap ID</th>
                                <th text-translate="true">Type</th>
                                <th text-translate="true">Amount</th>
                                <th text-translate="true">Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var swap in Model.RecentSwaps)
                            {
                                var boltzSwapLink = ArkadeLinkHelper.GetSwapLink(ArkNetworkConfig, swap.SwapId);
                                <tr>
                                    <td>
                                        <vc:truncate-center text="@swap.SwapId" link="@boltzSwapLink" classes="truncate-center-id"/>
                                    </td>
                                    <td>
                                        @if (swap.SwapType == ArkSwapType.ReverseSubmarine)
                                        {
                                            <span class="badge text-bg-primary">Reverse</span>
                                        }
                                        else
                                        {
                                            <span class="badge text-bg-info">Submarine</span>
                                        }
                                    </td>
                                    <td>@Money.Satoshis(swap.ExpectedAmount).ToDecimal(MoneyUnit.BTC) BTC</td>
                                    <td>
                                        @{
                                            var swapBadge = swap.Status switch
                                            {
                                                ArkSwapStatus.Pending => "text-bg-info",
                                                ArkSwapStatus.Settled => "text-bg-success",
                                                ArkSwapStatus.Failed => "text-bg-danger",
                                                _ => "text-bg-warning"
                                            };
                                        }
                                        <span class="badge @swapBadge">@Enum.GetName(typeof(ArkSwapStatus), swap.Status)</span>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <p class="text-muted text-center mb-0">No swaps yet</p>
            }
        </div>
    </div>
</div>

<!-- Auto-Sweep Configuration Modal -->
@if (Model.CanManagePrivateKeys)
{
    <div class="modal fade" id="autoSweepModal" tabindex="-1" aria-labelledby="autoSweepModalLabel" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="autoSweepModalLabel">Auto-Sweep Configuration</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <form asp-action="UpdateWalletConfig" method="post" asp-route-storeId="@storeId">
                    <div class="modal-body">
                        <p class="text-muted small mb-3">
                            Auto-sweep automatically sends all received funds to a specified Arkade address.
                            This is useful for forwarding payments to another wallet.
                        </p>

                        @if (!string.IsNullOrEmpty(Model.Destination))
                        {
                            <div class="mb-3">
                                <label class="form-label">Current Destination</label>
                                <div class="input-group">
                                    <input type="text" class="form-control font-monospace" value="@Model.Destination" readonly />
                                </div>
                            </div>
                            <div class="alert alert-info small">
                                <strong>Auto-sweep is enabled.</strong> All received funds will be automatically forwarded to this address.
                            </div>
                        }
                        else
                        {
                            <div class="mb-3">
                                <label asp-for="Destination" class="form-label">Destination Address</label>
                                <input asp-for="Destination" class="form-control font-monospace" placeholder="ark1..." />
                                <div class="form-text">Enter an Arkade address to receive swept funds.</div>
                            </div>
                        }
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                        @if (!string.IsNullOrEmpty(Model.Destination))
                        {
                            <button type="submit" name="command" value="clear-destination" class="btn btn-outline-danger">
                                Disable Auto-Sweep
                            </button>
                        }
                        else
                        {
                            <button type="submit" name="command" value="save" class="btn btn-primary">
                                Enable Auto-Sweep
                            </button>
                        }
                    </div>
                </form>
            </div>
        </div>
    </div>
}

<!-- Boarding Configuration Modal -->
@if (Model.WalletType == WalletType.HD)
{
    <div class="modal fade" id="boardingModal" tabindex="-1" aria-labelledby="boardingModalLabel" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="boardingModalLabel">Boarding Configuration</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <form asp-action="UpdateWalletConfig" method="post" asp-route-storeId="@storeId">
                    <div class="modal-body">
                        <p class="text-muted small mb-3">
                            Boarding allows customers to pay invoices using an on-chain Bitcoin transaction.
                            The funds are moved into the Arkade VTXO tree in the next batch round.
                            Only available when the store has no on-chain BTC payment method configured.
                        </p>

                        <div class="mb-3">
                            <label asp-for="MinBoardingAmountSats" class="form-label">Minimum Amount (sats)</label>
                            <input asp-for="MinBoardingAmountSats" class="form-control" type="number" min="330"
                                   value="@Model.MinBoardingAmountSats" />
                            <div class="form-text">Invoices below this amount will not include a boarding address. Minimum: 330 sats (P2TR dust threshold).</div>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                        @if (Model.BoardingEnabled)
                        {
                            <button type="submit" name="command" value="disable-boarding" class="btn btn-outline-danger">
                                Disable Boarding
                            </button>
                            <button type="submit" name="command" value="save-boarding" class="btn btn-primary">
                                Save
                            </button>
                        }
                        else
                        {
                            <button type="submit" name="command" value="save-boarding" class="btn btn-primary">
                                Enable Boarding
                            </button>
                        }
                    </div>
                </form>
            </div>
        </div>
    </div>
}

<!-- Clear Wallet Modal -->
<div class="modal fade" id="clearWalletModal" tabindex="-1" aria-labelledby="clearWalletModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="clearWalletModalLabel">
                    <vc:icon symbol="warning" /> Clear Wallet Configuration
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form asp-action="ClearWallet" method="post" asp-route-storeId="@storeId">
                <div class="modal-body">
                    <div class="alert alert-warning">
                        <strong>Warning:</strong> This will remove the Arkade wallet configuration from this store.
                    </div>
                    <p class="mb-3">Are you sure you want to clear the wallet configuration? This action will:</p>
                    <ul>
                        <li>Remove the Arkade payment method from this store</li>
                        <li>Disable Lightning if enabled via Arkade</li>
                        <li>Not delete any funds or VTXOs (they remain on the network)</li>
                    </ul>
                    @if (Model.SignerAvailable && !string.IsNullOrEmpty(Model.Wallet))
                    {
                        <div class="alert alert-info">
                            <strong>Important:</strong> Make sure you have backed up your private key before clearing. You can view it using the "Show Private Key" button.
                        </div>
                    }
                    <p class="text-muted mb-0">You can re-import the wallet later using the same private key or wallet ID.</p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-danger">Clear Wallet</button>
                </div>
            </form>
        </div>
    </div>
</div>

